{
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    },
    "functions": [
        {
            "source": "functions",
            "codebase": "default",
            "ignore": [
                "node_modules",
                ".git",
                "firebase-debug.log",
                "firestore-debug.log",
                "ui-debug.log"
            ],
            "predeploy": [
                "npm run build"
            ]
        }
    ],
    "storage": {
        "rules": "storage.rules"
    },
    "hosting": [
        {
            "target": "admin",
            "source": "admin_app"
        },
        {
            "target": "customer",
            "source": "customer_app"
        }
    ]
}